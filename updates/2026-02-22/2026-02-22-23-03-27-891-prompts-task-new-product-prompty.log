,\n    \"sources\": [\"Product Hunt\"],\n    \"community_quotes\": [\"192 upvotes\", \"Real-time preview\", \"Full-stack development\"]\n  },\n  {\n    \"name\": \"Qwen Code\",\n    \"url\": \"https://github.com/QwenLM/Qwen3.5\",\n    \"description\": \"Open-source AI agent for the terminal, optimized for Qwen models. Part of Qwen3.5 focusing on native multimodal agents.\",\n    \"release_date\": \"2026-02-17\",\n    \"category\": \"AI coding CLI\",\n    \"sources\": [\"GitHub\"],\n    \"community_quotes\": [\"Open-source terminal agent\", \"Optimized for Qwen models\", \"Part of Qwen3.5 release\"]\n  },\n  {\n    \"name\": \"Code Arena\",\n    \"url\": \"https://producthunt.com/posts/code-arena\",\n    \"description\": \"Compare multiple AI development applications at once. Input a single prompt and compare outputs from top AI programming models side-by-side, then export ready-to-run code to GitHub or your IDE.\",\n    \"release_date\": \"2026-02-13\",\n    \"category\": \"AI coding comparison tool\",\n    \"sources\": [\"Product Hunt\"],\n    \"community_quotes\": [\"283 upvotes\", \"Compare multiple AI models simultaneously\", \"Free for developers\", \"Featured product\"]\n  },\n  {\n    \"name\": \"Cline CLI\",\n    \"url\": \"https://producthunt.com/posts/cline-cli\",\n    \"description\": \"Command-line tool for automated coding with parallel agents, CI/CD integration, headless mode, and ACP support. Multi-editor compatibility for developers.\",\n    \"release_date\": \"2026-02-14\",\n    \"category\": \"AI coding CLI\",\n    \"sources\": [\"Product Hunt\"],\n    \"community_quotes\": [\"255 upvotes\", \"Open-source software\", \"Automated coding tool\", \"Featured product\"]\n  },\n  {\n    \"name\": \"GitHub Agentic Workflows\",\n    \"url\": \"https://github.blog/ai-and-ml/automate-repository-tasks-with-github-agentic-workflows/\",\n    \"description\": \"GitHub's automation platform for AI agents in CI/CD pipelines. Integrates AI agents with deployment practices for automated status reports.\",\n    \"release_date\": \"2026-02-13\",\n    \"category\": \"AI orchestration platform\",\n    \"sources\": [\"GitHub Blog\"],\n    \"community_quotes\": [\"Continuous AI works best with CI/CD\", \"Automated repository tasks\", \"AI agent integration\"]\n  },\n  {\n    \"name\": \"Oz\",\n    \"url\": \"https://producthunt.com/posts/oz\",\n    \"description\": \"Cloud agent orchestration platform enabling parallel execution of hundreds of cloud agents. Quick startup with production-ready PR management via CLI or mobile.\",\n    \"release_date\": \"2026-02-11\",\n    \"category\": \"AI orchestration platform\",\n    \"sources\": [\"Product Hunt\"],\n    \"community_quotes\": [\"176 upvotes\", \"Cloud agent orchestration\", \"Parallel execution\", \"CLI and mobile support\"]\n  },\n  {\n    \"name\": \"Axel\",\n    \"url\": \"https://producthunt.com/posts/axel\",\n    \"description\": \"AI programming assistant - native macOS application for work scheduling and task management. Integrates with Claude and supports Codex with keyboard-driven operation.\",\n    \"release_date\": \"2026-02-09\",\n    \"category\": \"AI coding assistant\",\n    \"sources\": [\"Product Hunt\"],\n    \"community_quotes\": [\"249 upvotes\", \"Native macOS app\", \"Keyboard-driven operation\"]\n  }\n]\n",
