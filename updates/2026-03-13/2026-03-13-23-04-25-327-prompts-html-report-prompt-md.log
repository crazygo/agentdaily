        "content": "     1→[\n     2→  {\n     3→    \"productName\": \"Cursor\",\n     4→    \"title\": \"Automations - Always-On Agents Framework\",\n     5→    \"description\": \"Cursor launched Automations, a major new feature for building always-on agents that run based on triggers and schedules. Agents can be triggered by events from Slack, Linear, GitHub, PagerDuty, and webhooks, with access to MCPs and memory tools for learning from past runs.\",\n     6→    \"updateType\": \"feature\",\n     7→    \"url\": \"https://cursor.com/automations\",\n     8→    \"date\": \"2026-03-05\",\n     9→    \"community_feedback\": [\n    10→      {\n    11→        \"quote\": \"Cursor now has 2x more agent users than Tab users - a massive shift toward agentic AI coding workflows\",\n    12→        \"source\": \"Blog\",\n    13→        \"sentiment\": \"positive\"\n    14→      }\n    15→    ]\n    16→  },\n    17→  {\n    18→    \"productName\": \"Cursor\",\n    19→    \"title\": \"New Plugins on Cursor Marketplace\",\n    20→    \"description\": \"Added more than 30 new plugins from partners including Atlassian, Datadog, GitLab, Glean, Hugging Face, monday.com, and PlanetScale. Plugins contain MCPs that cloud agents can use when triggered manually or through automations.\",\n    21→    \"updateType\": \"feature\",\n    22→    \"url\": \"https://cursor.com/changelog\",\n    23→    \"date\": \"2026-03-11\",\n    24→    \"community_feedback\": []\n    25→  },\n    26→  {\n    27→    \"productName\": \"Cursor\",\n    28→    \"title\": \"Cursor in JetBrains IDEs\",\n    29→    \"description\": \"Cursor is now available in IntelliJ IDEA, PyCharm, WebStorm, and other JetBrains IDEs through the Agent Client Protocol (ACP), allowing developers to use frontier models from OpenAI, Anthropic, Google, and Cursor for agent-driven development.\",\n    30→    \"updateType\": \"feature\",\n    31→    \"url\": \"https://cursor.com/changelog\",\n    32→    \"date\": \"2026-03-04\",\n    33→   