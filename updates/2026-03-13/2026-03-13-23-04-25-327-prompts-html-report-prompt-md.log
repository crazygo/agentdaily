    "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Agentic Coding Research Report - 2026-03-13</title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: Verdana, Geneva, sans-serif;\n            font-size: 10pt;\n            background-color: #f6f6ef;\n            color: #000000;\n            line-height: 1.5;\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            background-color: #f6f6ef;\n        }\n\n        header {\n            background-color: #ff6600;\n            padding: 5px 10px;\n            border-bottom: 1px solid #d4d4d4;\n        }\n\n        header h1 {\n            font-family: Arial, Helvetica, sans-serif;\n            font-size: 14pt;\n            font-weight: bold;\n            color: #000000;\n        }\n\n        .header-nav {\n            font-size: 9pt;\n            margin-top: 5px;\n        }\n\n        .header-nav a {\n            color: #000000;\n            text-decoration: none;\n            margin-right: 15px;\n        }\n\n        .header-nav a:hover {\n            text-decoration: underline;\n        }\n\n        .report-meta {\n            background-color: #ff6600;\n            padding: 5px 10px;\n            font-size: 9pt;\n            color: #000000;\n        }\n\n        .three-column-layout {\n            display: grid;\n            grid-template-columns: 40% 35% 25%;\n            gap: 10px;\n            padding: 10px;\n        }\n\n        @media (max-width: 1024px) {\n            .three-column-layout {\n                grid-template-columns: 1fr 1fr;\n            }\n        }\n\n        @media (max-width: 768px) {\n            .three-column-layout {\n                grid-template-columns: 1fr;\n            }\n        }\n\n     