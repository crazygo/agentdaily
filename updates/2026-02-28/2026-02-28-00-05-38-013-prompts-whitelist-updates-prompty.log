  }\n    ]\n  },\n  {\n    \"productName\": \"Cursor\",\n    \"title\": \"Version 0.46 - Agent Default Mode\",\n    \"description\": \"Agent became the default mode for users, UI refresh, and Web search integration. Part of Cursor's aggressive development cycle leading up to version 1.0, establishing Agent mode as the core interaction paradigm.\",\n    \"updateType\": \"release\",\n    \"url\": \"https://cursor.sh\",\n    \"date\": \"2025-02-01\",\n    \"community_feedback\": [\n      {\n        \"quote\": \"Foundational steps that eventually led to Cursor 2.0 with major breakthroughs\",\n        \"source\": \"Version history analysis\",\n        \"sentiment\": \"positive\"\n      }\n    ]\n  },\n  {\n    \"productName\": \"Windsurf\",\n    \"title\": \"Wave 4 Release\",\n    \"description\": \"Major update featuring Previews for real-time code modification viewing, Tab to Import for dependency management, Cascade assistant for intelligent suggestions, integrated Linter for code quality checking, and click-to-edit functionality support.\",\n    \"updateType\": \"release\",\n    \"url\": \"https://codeium.com/windsurf\",\n    \"date\": \"2025-03-05\",\n    \"community_feedback\": [\n      {\n        \"quote\": \"Windsurf was acquired by Cognition (Devin's parent company) in July 2025, with core team recruited by Google DeepMind\",\n        \"source\": \"Industry news\",\n        \"sentiment\": \"neutral\"\n      },\n      {\n        \"quote\": \"Devin appears to be 'encroaching on' Windsurf's user base as the technologies integrate\",\n        \"source\": \"Market analysis\",\n        \"sentiment\": \"negative\"\n      }\n    ]\n  },\n  {\n    \"productName\": \"Continue\",\n    \"title\": \"IDEA Plugin Version 0.0.88\",\n    \"description\": \"Released IDEA plugin update supporting deployment of DeepSeek and other AI large models for coding assistance in IntelliJ IDEA environments.\",\n    \"updateType\": \"release\",\n    \"url\": \"https://continue.dev\",\n    \"date\": \"2025-02-24\",\n    \"community_feedback\": [\n      {\n        \"quote\": \"Open-source AI code assistant with 27,141+ GitHub stars as of June 2025\",\n        \"source\": \"GitHub metrics\",\n        \"sentiment\": \"positive\"\n      }\n    ]\n  }\n]\n"
