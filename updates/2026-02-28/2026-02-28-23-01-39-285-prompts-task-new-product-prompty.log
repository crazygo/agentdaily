ces\": [\"Product Hunt\"],\n    \"community_quotes\": [\"368 upvotes on Product Hunt\", \"Full-stack vibe coding\", \"Collaborative AI assistant\"]\n  },\n  {\n    \"name\": \"Claude Code Agent Teams\",\n    \"url\": \"https://github.com/anthropics/claude-code\",\n    \"description\": \"Experimental release of agent teams for Claude Code in February 2026. Introduces test-driven development (TDD) workflows with Red-Green-Refactor, multi-agent collaboration, and enhanced agentic execution modes.\",\n    \"release_date\": \"2026-02-10\",\n    \"category\": \"AI coding CLI\",\n    \"sources\": [\"GitHub\"],\n    \"community_quotes\": [\"TDD workflows with Red-Green-Refactor\", \"Multi-agent collaboration\", \"Enhanced agentic execution\"]\n  },\n  {\n    \"name\": \"Microsoft Agentic DevOps Series\",\n    \"url\": \"https://developer.microsoft.com/reactor\",\n    \"description\": \"Microsoft's February 2026 agentic DevOps initiative featuring 'Modernize your Java apps in days with AI Agents' (Feb 18) and 'AI-powered workflows with GitHub and Azure DevOps' (Feb 25). Focus on autonomous AI agents for Java app migration and agent-based DevOps automation.\",\n    \"release_date\": \"2026-02-18\",\n    \"category\": \"workflow agent\",\n    \"sources\": [\"Microsoft Reactor\"],\n    \"community_quotes\": [\"Java app modernization with AI agents\", \"Agent-based DevOps automation\", \"Multi-agent orchestration\"]\n  }\n]",
