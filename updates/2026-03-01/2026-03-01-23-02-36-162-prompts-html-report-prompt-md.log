 #000000;\n            margin-bottom: 12px;\n            padding-bottom: 8px;\n            border-bottom: 1px solid #ff6600;\n        }\n\n        /* Content Items */\n        .item {\n            margin-bottom: 12px;\n            padding-bottom: 12px;\n            border-bottom: 1px dotted #d4d4d4;\n        }\n\n        .item:last-child {\n            border-bottom: none;\n            margin-bottom: 0;\n            padding-bottom: 0;\n        }\n\n        .item-title {\n            font-size: 10pt;\n            font-weight: normal;\n        }\n\n        .item-title a {\n            color: #000000;\n            text-decoration: none;\n        }\n\n        .item-title a:visited {\n            color: #828282;\n        }\n\n        .item-title a:hover {\n            text-decoration: underline;\n        }\n\n        .item-description {\n            font-size: 9pt;\n            color: #828282;\n            margin-top: 4px;\n            line-height: 1.4;\n        }\n\n        .item-meta {\n            font-size: 8pt;\n            color: #828282;\n            margin-top: 4px;\n            font-family: Monaco, Consolas, monospace;\n        }\n\n        .tag {\n            display: inline-block;\n            background-color: #f6f6ef;\n            color: #828282;\n            padding: 2px 6px;\n            margin: 2px;\n            font-size: 8pt;\n            border-radius: 2px;\n        }\n\n        /* Empty State */\n        .empty-state {\n            font-size: 9pt;\n            color: #828282;\n            font-style: italic;\n            padding: 20px 10px;\n            text-align: center;\n        }\n\n        /* Footer */\n        footer {\n            margin-top: 20px;\n            padding: 15px 10px;\n            border-top: 1px solid #d4d4d4;\n            text-align: center;\n            font-size: 9pt;\n            color: #828282;\n        }\n\n        footer a {\n            color: #828282;\n            text-decoration: none;\n        }\n\n        footer a:hover {\n            text-decoration: underline;\n        }\n\n        /* Responsive Design */\n        @media (max-width: 1200px) {\n            .three-column-layout {\n                grid-template-columns: 1fr 1fr;\n            }\n\n            .technical-insights {\n                grid-column: 1 / -1;\n            }\n        }\n\n        @media (max-width: 768px) {\n            .three-column-layout {\n                grid-template-columns: 1fr;\n            }\n\n            header h1 {\n                flex-direction: column;\n                align-items: flex-start;\n            }\n\n            .section {\n                padding: 10px;\n            }\n        }\n\n        /* Print Styles */\n        @media print {\n            body {\n                background-color: #ffffff;\n            }\n\n            .section {\n                page-break-inside: avoid;\n                border: 1px solid #000000;\n            }\n\n            header {\n                background-color: #ffffff;\n                border-bottom: 2px solid #000000;\n            }\n\n            a {\n                color: #000000;\n                text-decoration: underline;\n            }\n        }\n\n        /* Utility Classes */\n        .badge {\n            display: inline-block;\n            padding: 2px 6px;\n            font-size: 8pt;\n            border-radius: 2px;\n            margin-left: 5px;\n        }\n\n        .badge-new {\n            background-color: #ff6600;\n            color: #ffffff;\n        }\n\n        .badge-update {\n            background-color: #0066ff;\n            color: #ffffff;\n        }\n\n        .version {\n            font-family: Monaco, Consolas, monospace;\n            background-color: #f6f6ef;\n            padding: 2px 6px;\n            font-size: 8pt;\n            color: #828282;\n        }\n    </style>\n</head>\n<body>\n    <header>\n        <div class=\"container\">\n            <h1>\n                <span>🤖 Agentic Coding Research Report</span>\n                <span class=\"date\">2026-03-01</span>\n            </h1>\n        </div>\n    </header>\n\n    <main class=\"container\">\n        <div class=\"three-column-layout\">\n            <!-- New Products Section (40% width) -->\n            <section class=\"new-products section\">\n                <h2>New Products</h2>\n                <div class=\"empty-state\">\n                    No new products found in this research cycle.\n                </div>\n            </section>\n\n            <!-- Whitelist Updates Section (35% width) -->\n            <section class=\"whitelist-updates section\">\n                <h2>Product Updates</h2>\n                <div class=\"empty-state\">\n                    No updates found for tracked products.\n                </div>\n            </section>\n\n            <!-- Technical Insights Section (25% width) -->\n            <section class=\"technical-insights section\">\n                <h2>Insights & Opinions</h2>\n                <div class=\"empty-state\">\n                    No new insights gathered.\n                </div>\n            </section>\n        </div>\n    </main>\n\n    <footer>\n        <div class=\"container\">\n            <p>Report generated by Agent Code Daily - Powered by Claude Agent SDK</p>\n            <p style=\"margin-top: 5px; font-size: 8pt;\">\n                <a href=\"#\">Archive</a> |\n                <a href=\"#\">About</a> |\n                <a href=\"#\">Subscribe</a>\n            </p>\n        </div>\n    </footer>\n</body>\n</html>\n",
