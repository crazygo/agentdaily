  "old_string": "[\n  {\n    \"name\": \"OpenAI Codex macOS App\",\n    \"url\": \"https://techcrunch.com/2026/02/02/openai-launches-new-macos-app-for-agentic-coding/\",\n    \"description\": \"OpenAI released a new macOS desktop application for Codex, their agentic coding tool. The app features multi-agent parallel work, automated task scheduling, and customizable agent personalities. It builds on the GPT-5.2-Codex model and provides a flexible interface for sophisticated agentic coding workflows.\",\n    \"release_date\": \"2026-02-02\",\n    \"category\": \"AI coding CLI\",\n    \"sources\": [\"TechCrunch\", \"Product Hunt\"],\n    \"community_quotes\": [\n      \"\\\"If you really want to do sophisticated work on something complex, 5.2 is the strongest model by far\\\" - Sam Altman, OpenAI CEO\",\n      \"\\\"You can use this from a clean sheet of paper, brand new, to make a really quite sophisticated piece of software in a few hours\\\" - Sam Altman\",\n      \"Benchmark shows GPT-5.2-Codex holds top spot on TerminalBench for command-line programming tasks\"\n    ]\n  },\n  {\n    \"name\": \"Xcode 26.3 with Agentic Coding\",\n    \"url\": \"https://www.apple.com/newsroom/2026/02/xcode-26-point-3-unlocks-the-power-of-agentic-coding/\",\n    \"description\": \"Apple released Xcode 26.3 with native integration of AI coding agents from OpenAI (Codex) and Anthropic (Claude). The update represents a shift from AI copilot providing suggestions to AI agents capable of autonomous task execution. Features include Model Context Protocol (MCP) support for third-party AI providers and fine-grained permission control for secure AI-assisted development.\",\n    \"release_date\": \"2026-02-27\",\n    \"category\": \"AI IDE integration\",\n    \"sources\": [\"Apple Newsroom\", \"TechCrunch\", \"InfoQ\"],\n    \"community_quotes\": [\n      \"AI programming evolved from 'giving suggestions' to 'writing code'\",\n      \"从'助手'进化为'代工' - from 'assistant' to 'contractor'\",\n      